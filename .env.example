# Copia este fichero a `.env` y rellena los valores. `docker compose` lo carga automáticamente.

# --- ByteHide Runtime (OBLIGATORIO) ---
# Tokens de proyecto de ByteHide Runtime. Dos claves: una para los servicios Python (workshop +
# chatbot) y otra para el servicio Java (identity). Pueden ser del mismo proyecto o de dos distintos.
MONITOR_PYTHON_KEY=bh_xxxxxxxxxxxxxxxxxxxxxxxx   # workshop + chatbot
MONITOR_JAVA_KEY=bh_xxxxxxxxxxxxxxxxxxxxxxxx     # identity

# Cadencia del heartbeat en ms (vacío = valor por defecto del backend, ~60s). 10000 = ~10s.
BYTEHIDE_HEARTBEAT_MS=

# Logs detallados del runtime (Python y Java). Vacío/0 = off; 1 = on.
MONITOR_DEBUG=
# Entorno del backend: vacío/0 = producción; 1 = staging.
MONITOR_STAGING=

# Bloqueo de sesión: 1 = al detectar un ataque bloquea toda la sesión del atacante; 0 = bloquea solo
# esa petición. Con 0 cada petición se evalúa por separado (recomendado al ejecutar el harness).
MONITOR_SESSION_BLOCK=0

# --- ByteHide AI Runtime / LLM del chatbot (OBLIGATORIO para los retos LLM 16-18) ---
# Proveedor por defecto: openai. Pon la API key del proveedor que uses.
CHATBOT_LLM_PROVIDER=openai
CHATBOT_OPENAI_API_KEY=

# --- crAPI (opcionales) ---
# VERSION=latest
# LISTEN_IP=127.0.0.1
# ENABLE_SHELL_INJECTION=false
# ENABLE_LOG4J=false

# --- Puertos publicados (cámbialos si ya tienes otra pila de crAPI ocupándolos) ---
# WEB_PORT=8888          # UI/API   (http://localhost:8888)
# WEB_TLS_PORT=8443      # UI/API TLS
# MAILHOG_PORT=8025      # bandeja de mails (OTP del reto 3)
# CHATBOT_MCP_PORT=5500  # MCP server del chatbot
